# ─── Infrastructure ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nemoclaw
POSTGRES_PASSWORD=AsusJJ@@#)!5
POSTGRES_DB=nemoclaw

REDIS_URL=redis://redis:6379/0

# ─── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=nemoclaw
KEYCLOAK_CLIENT_ID=nemoclaw-api
KEYCLOAK_CLIENT_SECRET=changeme

# ─── Sandbox Service ──────────────────────────────────────────
# "mock" = MockAdapter (no NemoClaw needed)
# "nemoclaw" = real NemoClaw CLI (requires Ubuntu + NemoClaw installed)
SANDBOX_BACKEND=mock
NEMOCLAW_BIN=/usr/local/bin/nemoclaw

# ─── Inference Gateway ────────────────────────────────────────
# Default provider when tenant has no preference
INFERENCE_DEFAULT_PROVIDER=nvidia

NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ─── Billing ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme

# ─── Service ports (local dev) ────────────────────────────────
TENANT_PORT=3001
SANDBOX_PORT=3002
INFERENCE_GW_PORT=3003
BILLING_PORT=3004

# ─── Account Authentication ────────────────────────────────
# mock / keycloak
AUTH_MODE=mock
