# ─── Sandbox Service ──────────────────────────────────────────
# mock      → Windows / Unit Test（完全不需要外部依賴）
# k8s       → Ubuntu 整合測試（真正 Namespace-per-Tenant）← 推薦
# openshell → Ubuntu（平坦架構，名稱有前綴問題，備用）
SANDBOX_BACKEND=k8s
NEMOCLAW_BIN=/usr/local/bin/nemoclaw

# ─── Inference Gateway ────────────────────────────────────────
